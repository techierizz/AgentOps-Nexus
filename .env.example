# ═══════════════════════════════════════════════════════════════
# AgentOps Nexus — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Runtime Mode ──────────────────────────────────────────────
# "demo"       = fallbacks allowed, local repos, simulator agents
# "production" = all dependencies mandatory, zero fallbacks
RUNTIME_MODE=demo

# ── Agent Mode ────────────────────────────────────────────────
# "simulator" = deterministic, no LLM calls, fast local execution
# "llm"       = uses live LLM providers for reasoning
AGENT_MODE=simulator

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Paths (override if needed — defaults are auto-resolved) ──
# BASE_DIR=          # auto: project root
# DEMO_REPO_PATH=    # auto: <BASE_DIR>/demo_target_repo
# EVIDENCE_DIR=      # auto: <BASE_DIR>/artifacts

# ── GitHub Integration ────────────────────────────────────────
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_WEBHOOK_SECRET=your_webhook_secret
# GITHUB_REPO_OWNER=your-org
# GITHUB_REPO_NAME=your-repo

# ── LLM Providers ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PRIMARY_MODEL=gemini-2.5-flash

# ── Budget Limits (per run) ───────────────────────────────────
MAX_TOKENS_PER_RUN=500000
MAX_COST_PER_RUN=5.00
MAX_EXECUTION_SECONDS=600
MAX_FILES_MODIFIED=10
MAX_LINES_CHANGED=500
MAX_PATCH_ITERATIONS=3
